# Public (bundled into the client)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (Vercel env vars; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# NowPayments crypto checkout
# Generate API key under Settings → API key.
# Generate IPN Secret under Store Settings → IPN Setup.
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret
# 'sandbox' (default) targets api-sandbox.nowpayments.io; 'prod' targets api.nowpayments.io
NOWPAYMENTS_ENV=sandbox

# Used for success/cancel/IPN URLs in the invoice.
# Falls back to VERCEL_URL or the request host if unset.
SITE_URL=https://aminoselect.com
