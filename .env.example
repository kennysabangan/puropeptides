# Public (bundled into the client)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only (Vercel env vars; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Peer Pay (zkp2p) crypto checkout
VITE_PEER_API_KEY=your_peer_api_key
VITE_PEER_WEBHOOK_SECRET=your_webhook_secret
VITE_PEER_API_BASE_URL=https://api.pay.peer.xyz
VITE_PEER_CHECKOUT_BASE_URL=https://pay.peer.xyz
VITE_PEER_DESTINATION_ADDRESS=0xYourWalletAddress
VITE_PEER_DESTINATION_CHAIN_ID=8453

# Used for success/cancel URLs.
SITE_URL=https://aminoselect.com
